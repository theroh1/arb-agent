# Required: AWS Bedrock authentication
#
# Option A — Bedrock API key (recommended for this project)
# Generate in the AWS console: Bedrock → API keys → Generate
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here

# Option B — Standard AWS credentials (uncomment if not using a Bedrock API key)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...   # only if using temporary credentials

# Required: AWS region where the Qwen model is enabled in Bedrock
AWS_REGION=us-east-1

# Optional: Bedrock model ID
# Default: qwen.qwen3-coder-480b-a35b-v1:0
# Other Qwen options:
#   qwen.qwen3-235b-a22b-2507-v1:0   (general reasoning — recommended for HLD review)
#   qwen.qwen3-32b-v1:0              (cheaper, faster)
BEDROCK_MODEL_ID=qwen.qwen3-coder-480b-a35b-v1:0
